datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        BigInt   @id @default(autoincrement())
  username  String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  devices   UserDevice[]
  chatrooms Chatroom[]

  @@map("users")
}

model UserDevice {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @map("user_id")
  deviceToken  String   @unique @map("device_token") @db.VarChar(512)
  registeredAt DateTime @default(now()) @map("registered_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_devices")
}

model Chatroom {
  id                  BigInt    @id @default(autoincrement())
  userId              BigInt    @map("user_id")
  name                String    @db.VarChar(255)
  basePrompt          String?   @map("base_prompt") @db.Text
  profileImageUrl     String?   @map("profile_image_url") @db.VarChar(255)
  currentDelaySeconds Int       @default(60) @map("current_delay_seconds")
  nextEvaluationTime  DateTime? @map("next_evaluation_time")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chatrooms")
}

enum Sender {
  user
  ai
}

model Message {
  id         BigInt   @id @default(autoincrement())
  chatroomId BigInt   @map("chatroom_id")
  sender     Sender
  content    String   @db.LongText
  createdAt  DateTime @default(now()) @map("created_at")

  chatroom Chatroom @relation(fields: [chatroomId], references: [id], onDelete: Cascade)

  @@map("messages")
}
